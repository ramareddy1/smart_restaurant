generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── USER ROLES ───────────────────────────────────────────────

enum UserRole {
  OWNER
  KITCHEN_MANAGER
  HEAD_CHEF
  SERVER
  HOST
}

// ─── RESTAURANT ───────────────────────────────────────────────

model Restaurant {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  timezone  String   @default("America/New_York")
  createdAt DateTime @default(now()) @map("created_at")

  users    User[]
  settings RestaurantSettings?

  @@map("restaurants")
}

model RestaurantSettings {
  id              String @id @default(cuid())
  restaurantId    String @unique @map("restaurant_id")
  targetFoodCost  Float  @default(0.30) @map("target_food_cost")
  targetLaborCost Float  @default(0.28) @map("target_labor_cost")
  currency        String @default("USD")
  fiscalYearStart Int    @default(1) @map("fiscal_year_start")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("restaurant_settings")
}

// ─── USER ─────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  role         UserRole
  pin          String?
  restaurantId String    @map("restaurant_id")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  restaurant      Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  sessions        Session[]
  purchaseOrders  PurchaseOrder[] @relation("PO_CreatedBy")
  receivings      Receiving[]     @relation("Receiving_ReceivedBy")
  prepTasks       PrepTask[]      @relation("PrepTask_AssignedTo")

  @@index([email])
  @@index([restaurantId])
  @@index([role])
  @@map("users")
}

// ─── SESSION ──────────────────────────────────────────────────

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

// ─── SUPPLIER ───────────────────────────────────────────────

model Supplier {
  id           String        @id @default(cuid())
  name         String
  contactEmail String?       @map("contact_email")
  contactPhone String?       @map("contact_phone")
  address      String?
  notes        String?
  createdAt    DateTime      @default(now()) @map("created_at")

  ingredients    Ingredient[]
  transactions   Transaction[]
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

// ─── INGREDIENT ─────────────────────────────────────────────

model Ingredient {
  id             String    @id @default(cuid())
  name           String
  category       String
  unit           String
  currentStock   Float     @default(0) @map("current_stock")
  parLevel       Float     @map("par_level")
  costPerUnit    Float     @map("cost_per_unit")
  expirationDate DateTime? @map("expiration_date")
  supplierId     String?   @map("supplier_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  supplier           Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  recipeIngredients  RecipeIngredient[]
  transactions       Transaction[]
  alerts             Alert[]
  purchaseOrderItems PurchaseOrderItem[]
  receivingItems     ReceivingItem[]
  allergens          IngredientAllergen[]

  @@index([name])
  @@index([category])
  @@index([expirationDate])
  @@index([supplierId])
  @@map("ingredients")
}

// ─── RECIPE ─────────────────────────────────────────────────

model Recipe {
  id              String   @id @default(cuid())
  name            String
  description     String?
  category        String?
  yieldQuantity   Float    @default(1) @map("yield_quantity")
  yieldUnit       String   @default("serving") @map("yield_unit")
  instructions    String?
  prepTimeMin     Int?     @map("prep_time_min")
  cookTimeMin     Int?     @map("cook_time_min")
  difficultyLevel String?  @map("difficulty_level")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  ingredients RecipeIngredient[]
  menuItems   MenuItem[]
  prepTasks   PrepTask[]

  @@map("recipes")
}

// ─── RECIPE INGREDIENT (join table) ─────────────────────────

model RecipeIngredient {
  id           String @id @default(cuid())
  recipeId     String @map("recipe_id")
  ingredientId String @map("ingredient_id")
  quantity     Float
  unit         String

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([recipeId, ingredientId])
  @@map("recipe_ingredients")
}

// ─── MENU ITEM ──────────────────────────────────────────────

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  category    String?
  recipeId    String?  @map("recipe_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  recipe Recipe?        @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  menus  MenuMenuItem[]

  @@map("menu_items")
}

// ─── MENU ───────────────────────────────────────────────────

model Menu {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  items MenuMenuItem[]

  @@map("menus")
}

// ─── MENU <-> MENU ITEM (join table) ────────────────────────

model MenuMenuItem {
  menuId     String @map("menu_id")
  menuItemId String @map("menu_item_id")

  menu     Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@id([menuId, menuItemId])
  @@map("menu_menu_items")
}

// ─── TRANSACTION ────────────────────────────────────────────

enum TransactionType {
  PURCHASE
  USAGE
  WASTE
  ADJUSTMENT
}

enum WasteReason {
  EXPIRED
  SPOILED
  OVERPRODUCTION
  DROPPED
  QUALITY_ISSUE
  OTHER
}

model Transaction {
  id           String          @id @default(cuid())
  type         TransactionType
  ingredientId String          @map("ingredient_id")
  quantity     Float
  unitCost     Float?          @map("unit_cost")
  totalCost    Float?          @map("total_cost")
  supplierId   String?         @map("supplier_id")
  notes        String?
  wasteReason  WasteReason?    @map("waste_reason")
  createdAt    DateTime        @default(now()) @map("created_at")

  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  supplier   Supplier?  @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([ingredientId])
  @@index([type])
  @@index([createdAt])
  @@map("transactions")
}

// ─── ALERT ──────────────────────────────────────────────────

enum AlertType {
  LOW_STOCK
  EXPIRING
  OVERSTOCK
  AI_RECOMMENDATION
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model Alert {
  id           String        @id @default(cuid())
  type         AlertType
  severity     AlertSeverity
  title        String
  message      String
  ingredientId String?       @map("ingredient_id")
  isRead       Boolean       @default(false) @map("is_read")
  isDismissed  Boolean       @default(false) @map("is_dismissed")
  createdAt    DateTime      @default(now()) @map("created_at")

  ingredient Ingredient? @relation(fields: [ingredientId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([isRead])
  @@index([isRead, isDismissed])
  @@index([createdAt])
  @@map("alerts")
}

// ─── PURCHASE ORDER ─────────────────────────────────────────

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  orderNumber  String              @unique @map("order_number")
  supplierId   String              @map("supplier_id")
  status       PurchaseOrderStatus @default(DRAFT)
  orderDate    DateTime            @default(now()) @map("order_date")
  expectedDate DateTime?           @map("expected_date")
  totalCost    Float?              @map("total_cost")
  notes        String?
  createdById  String              @map("created_by_id")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  supplier  Supplier            @relation(fields: [supplierId], references: [id])
  createdBy User                @relation("PO_CreatedBy", fields: [createdById], references: [id])
  items     PurchaseOrderItem[]
  receivings Receiving[]

  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
  @@index([createdById])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String @id @default(cuid())
  purchaseOrderId String @map("purchase_order_id")
  ingredientId    String @map("ingredient_id")
  quantityOrdered Float  @map("quantity_ordered")
  unitCost        Float  @map("unit_cost")
  quantityReceived Float @default(0) @map("quantity_received")

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  ingredient    Ingredient    @relation(fields: [ingredientId], references: [id])

  @@unique([purchaseOrderId, ingredientId])
  @@index([ingredientId])
  @@map("purchase_order_items")
}

// ─── RECEIVING ──────────────────────────────────────────────

model Receiving {
  id              String   @id @default(cuid())
  purchaseOrderId String   @map("purchase_order_id")
  receivedById    String   @map("received_by_id")
  receivedAt      DateTime @default(now()) @map("received_at")
  notes           String?

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  receivedBy    User          @relation("Receiving_ReceivedBy", fields: [receivedById], references: [id])
  items         ReceivingItem[]

  @@index([purchaseOrderId])
  @@index([receivedAt])
  @@map("receivings")
}

model ReceivingItem {
  id               String  @id @default(cuid())
  receivingId      String  @map("receiving_id")
  ingredientId     String  @map("ingredient_id")
  quantityReceived Float   @map("quantity_received")
  unitCost         Float   @map("unit_cost")
  qualityNotes     String? @map("quality_notes")

  receiving  Receiving  @relation(fields: [receivingId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@index([ingredientId])
  @@map("receiving_items")
}

// ─── ALLERGEN ──────────────────────────────────────────────

model Allergen {
  id   String @id @default(cuid())
  name String @unique

  ingredients IngredientAllergen[]

  @@map("allergens")
}

// ─── INGREDIENT <-> ALLERGEN (join table) ──────────────────

model IngredientAllergen {
  ingredientId String @map("ingredient_id")
  allergenId   String @map("allergen_id")

  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  allergen   Allergen   @relation(fields: [allergenId], references: [id], onDelete: Cascade)

  @@id([ingredientId, allergenId])
  @@map("ingredient_allergens")
}

// ─── PREP TASK ─────────────────────────────────────────────

enum PrepTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model PrepTask {
  id           String         @id @default(cuid())
  name         String
  recipeId     String?        @map("recipe_id")
  assignedToId String?        @map("assigned_to_id")
  scheduledFor DateTime       @map("scheduled_for")
  estimatedMin Int?           @map("estimated_min")
  status       PrepTaskStatus @default(PENDING)
  completedAt  DateTime?      @map("completed_at")
  notes        String?
  createdAt    DateTime       @default(now()) @map("created_at")

  recipe     Recipe? @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  assignedTo User?   @relation("PrepTask_AssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([scheduledFor])
  @@index([status])
  @@index([assignedToId])
  @@map("prep_tasks")
}
